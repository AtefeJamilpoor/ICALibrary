@model IEnumerable<DimainLayer.Model.Category>

@{
    ViewBag.Title = "مدیریت دسته‌بندی‌ها";
}

<div class="container mt-4" dir="rtl">
    <h2>مدیریت دسته‌بندی‌ها</h2>

    <!-- فرم افزودن/ویرایش -->
    <div id="formContainer">
        @await Html.PartialAsync("Partial/_CategoryForm", new DimainLayer.Model.Category())
    </div>

    <hr />

    <!-- لیست دسته‌ها -->
    <div id="listContainer">
        @await Html.PartialAsync("Partial/_CategoryList", Model)
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            // وقتی روی دکمه ویرایش کلیک شد
            $(".edit-btn").click(function () {
                var id = $(this).data("id");
                // فرم ویرایش را به صورت پارشال در همان بخش formContainer بارگذاری کن
                $("#formContainer").load("/Category/GetForm/" + id);
            });
        });
    </script>
}