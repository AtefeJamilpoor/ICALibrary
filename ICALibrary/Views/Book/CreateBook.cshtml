@model ServiceLayer.DTO.BookCreateDto;
@{
    ViewBag.Title = "ثبت کتاب جدید";
}

<div class="container mt-4" dir="rtl">
    <h2 class="mb-4">ثبت کتاب جدید</h2>

    <form asp-action="CreateBook" asp-controller="Book" method="post">
        <!-- عنوان کتاب -->
        <div class="mb-3">
            <label asp-for="Title" class="form-label">عنوان کتاب</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <!-- نویسنده -->
        <div class="mb-3">
            <label asp-for="Author" class="form-label">نویسنده</label>
            <input asp-for="Author" class="form-control" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>

        <!-- دسته‌بندی -->
        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label">دسته‌بندی</label>
            <select asp-for="CategoryId" Id="CategoryId" class="form-select"></select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <!-- دکمه‌ها -->
        <button type="submit" class="btn btn-success">ثبت کتاب</button>
        <a asp-action="Index" asp-controller="Book" class="btn btn-secondary">بازگشت</a>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // اتصال Kendo DropDownList به select
            $("#CategoryId").kendoDropDownList({
                optionLabel: "انتخاب دسته‌بندی...",
                dataTextField: "Name",
                dataValueField: "Id",
                dataSource: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Categories))
            });
        });
    </script>
}
