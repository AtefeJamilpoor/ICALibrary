@model List<ServiceLayer.ViewModel.CategoryPivotViewModel>
<body dir="rtl">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>دریافت گزارش</h2>
        <a asp-action="ShowingPrintReportingByCategories" class="btn btn-primary">
            <i class="bi bi-file-earmark-bar-graph"></i> دریافت گزارش Stimulsoft
        </a>
    </div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>نام دسته‌بندی</th>
            <th>تعداد کل</th>
            <th>درصد سهم</th>
            <th>قابل رزرو</th>
            <th>رزرو شده</th>
            <th>گم شده</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.CategoryName</td>
            <td>@item.BookCount</td>
            <td>@item.Percentage.ToString("F2") %</td>
            <td>@item.AvailableCount</td>
            <td>@item.BorrowedCount</td>
            <td>@item.LostCount</td>
        </tr>
    }
    </tbody>
</table>
</body>