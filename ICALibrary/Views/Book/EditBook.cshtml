@model ServiceLayer.DTO.BookCreateDto;
@{
}

<div class="container mt-4" dir="rtl">
    <h2 class="mb-4">ویرایش کتاب</h2>

    <form asp-action="EditBook" asp-controller="Book" method="post">
        <!-- عنوان کتاب -->
        <div class="mb-3">
            <label asp-for="Title" class="form-label">عنوان کتاب</label>
            <input asp-for="Title" class="form-control" value="@Model.Title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <!-- نویسنده -->
        <div class="mb-3">
            <label asp-for="Author" class="form-label">نویسنده</label>
            <input asp-for="Author" class="form-control" value="@Model.Author" />
            <span asp-validation-for="Author" class="text-danger"></span>
        </div>
        <!-- دسته‌بندی -->
        <div class="mb-3">
            <label asp-for="CategoryId" class="form-label">دسته‌بندی</label>
           
            <select asp-for="CategoryId" class="form-select" >
                @foreach (var category in @Model.Categories)
                {
                    if(category.Id== Model.CategoryId)
                    {
                        <option value="@Model.CategoryId">@Model.CategoryName</option>
                    }
                }
                @foreach (var category in @Model.Categories)
                {
                    if(category.Id!= Model.CategoryId)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <!-- دکمه‌ها -->
        <button type="submit" class="btn btn-success">ویرایش</button>
        <a asp-action="Index" asp-controller="Book" class="btn btn-secondary">بازگشت</a>
    </form>
</div>

